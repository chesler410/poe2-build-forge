{
  "name": "poe2-build-forge",
  "version": "0.0.0",
  "private": true,
  "description": "Convert Path of Exile 2 build guides into the in-game .build file format.",
  "license": "MIT",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "tsc -b",
    "dev": "pnpm --filter @poe2-build-forge/web dev",
    "spike:decode": "tsx scripts/decode-spike.ts",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "prune-data": "tsx scripts/prune-data.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
