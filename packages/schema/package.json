{
  "name": "@poe2-build-forge/schema",
  "version": "0.0.0",
  "description": "JSON Schema and runtime validator for Path of Exile 2 .build files.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./poe2-build.schema.json": "./src/poe2-build.schema.json"
  },
  "files": [
    "dist",
    "src/poe2-build.schema.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.4"
  }
}
